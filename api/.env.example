PORT=4000
# production: set NODE_ENV=production (required for HSTS, log levels, etc.)
NODE_ENV=development
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/localmarket?schema=public"
# Vitest integration tests (optional; defaults in vitest.config.ts if unset)
# TEST_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/localmarket_test?schema=public"
JWT_SECRET=change-me-to-at-least-32-characters-long
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30
BCRYPT_ROUNDS=12
# Optional: password for `npm run db:seed` test users (default Testpass123)
# SEED_TEST_PASSWORD=Testpass123
# Set to 1 behind nginx/caddy so rate limits use X-Forwarded-For
TRUST_PROXY=0
# Optional: if set, POST /payments/callback must send header X-Callback-Secret with this value
MPESA_CALLBACK_SECRET=
# Product images (Cloudinary). All three required for POST /uploads/product-image
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_UPLOAD_FOLDER=localmarket/products
# Optional: Redis — product cache + BullMQ background workers (payments / notifications / cleanup)
# REDIS_URL=redis://localhost:6379
# Request & error log retention for scheduled cleanup job (days)
# CLEANUP_LOG_RETENTION_DAYS=90
#
# OpenAI — optional; enables POST /assistant/openai/chat (function tools + live catalog)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
#
# Google AI Studio (Gemini) — optional; enables GET /assistant/gemini/status + POST /assistant/gemini/chat
# Create an API key at https://aistudio.google.com/apikey — put it HERE on the API server (not in the Flutter app).
# Use either variable name:
# GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=
# Default in code is gemini-2.5-flash (see https://ai.google.dev/gemini-api/docs/models)
# GEMINI_MODEL=gemini-2.5-flash-lite
#
# Production checklist (see repo docs / team runbook):
# - NODE_ENV=production, TRUST_PROXY=1 behind nginx/caddy/load balancer
# - Strong JWT_SECRET (32+ chars), DATABASE_URL to managed Postgres
# - npm ci && npx prisma generate && npm run build && npm run prisma:deploy && npm start
# - REDIS_URL for product cache + BullMQ workers (payments / notifications / log cleanup)
