PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/localmarket?schema=public"
# Vitest integration tests (optional; defaults in vitest.config.ts if unset)
# TEST_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/localmarket_test?schema=public"
JWT_SECRET=change-me-to-at-least-32-characters-long
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30
BCRYPT_ROUNDS=12
# Set to 1 behind nginx/caddy so rate limits use X-Forwarded-For
TRUST_PROXY=0
# Optional: if set, POST /payments/callback must send header X-Callback-Secret with this value
MPESA_CALLBACK_SECRET=
# Product images (Cloudinary). All three required for POST /uploads/product-image
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_UPLOAD_FOLDER=localmarket/products
# Optional: product catalog caching (list, nearby, related, by id)
# REDIS_URL=redis://localhost:6379
