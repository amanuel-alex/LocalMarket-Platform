generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  buyer
  seller
  admin
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  passwordHash String
  role         Role     @default(buyer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
