generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  buyer
  seller
  admin
}

enum OrderStatus {
  pending
  paid
  completed
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum WalletTransactionType {
  /** Buyer payment settled; funds held by platform, seller credited as pending (escrow). */
  order_escrow_in
  /** Pickup verified; seller pending → available, platform releases liability. */
  order_escrow_release
  /** Seller requested payout; available debited, payout record created. */
  payout_reserve
  /** Payout marked paid externally (no further balance change). */
  payout_complete
  /** Payout cancelled / failed; funds returned to seller available. */
  payout_cancel
  adjustment
}

enum PayoutStatus {
  pending
  paid
  failed
  cancelled
}

enum DisputeStatus {
  open
  reviewing
  resolved_refund
  resolved_no_action
  closed
}

model User {
  id                   String         @id @default(cuid())
  name                 String
  phone                String         @unique
  passwordHash         String
  role                 Role           @default(buyer)
  failedLoginAttempts  Int            @default(0)
  lockedUntil          DateTime?
  /** Shop / pickup coordinates for sellers (optional). Used for nearby product search. */
  sellerLat            Float?
  sellerLng            Float?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  products             Product[]
  ordersAsBuyer        Order[]        @relation("BuyerOrders")
  ordersAsSeller       Order[]        @relation("SellerOrders")
  refreshTokens        RefreshToken[]
  wallet               Wallet?
  payouts              Payout[]
}

model Wallet {
  id                String    @id @default(cuid())
  /** Set only for user wallets; null for the single platform treasury row. */
  userId            String?   @unique
  isPlatform        Boolean   @default(false)
  /** Funds the platform has collected (escrow float). */
  availableBalance  Decimal   @default(0) @db.Decimal(14, 2)
  /** Seller: earnings awaiting pickup / dispute window (mirrors platform liability for that seller). */
  pendingBalance    Decimal   @default(0) @db.Decimal(14, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      WalletTransaction[]
  payouts           Payout[]

  @@index([isPlatform])
  @@map("wallets")
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Restrict)
  type        WalletTransactionType
  amount      Decimal                  @db.Decimal(14, 2)
  orderId     String?
  paymentId   String?
  payoutId    String?
  note        String?
  createdAt   DateTime              @default(now())

  @@index([walletId])
  @@index([orderId])
  @@index([paymentId])
  @@index([payoutId])
  @@map("wallet_transactions")
}

model Payout {
  id          String       @id @default(cuid())
  walletId    String
  userId      String
  amount      Decimal      @db.Decimal(14, 2)
  status      PayoutStatus @default(pending)
  note        String?
  requestedAt DateTime     @default(now())
  completedAt DateTime?
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Restrict)
  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([walletId])
  @@index([status])
  @@map("payouts")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Decimal    @db.Decimal(14, 2)
  category    String
  lat         Float
  lng         Float
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sellerId])
  @@index([category])
}

model Order {
  id            String      @id @default(cuid())
  status        OrderStatus @default(pending)
  quantity      Int
  totalPrice    Decimal     @db.Decimal(14, 2)
  buyerId       String
  sellerId      String
  productId     String
  /** Secure one-time pickup token (raw); generated when payment succeeds — not the order id. */
  qrToken       String?     @unique
  qrConsumedAt  DateTime?
  /** Seller marked delivery / handover complete → eligible for admin escrow release. */
  deliveryConfirmedAt DateTime?
  /** Admin (or system) released escrow to seller available balance. */
  escrowReleasedAt    DateTime?
  buyer         User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  seller        User        @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  payments      Payment[]
  disputes      Dispute[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
}

model Dispute {
  id        String        @id @default(cuid())
  orderId   String        @map("order_id")
  reason    String
  status    DisputeStatus @default(open)
  /** Optional admin resolution / internal note (set when updating status). */
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@map("disputes")
}

model Payment {
  id                  String        @id @default(cuid())
  status              PaymentStatus @default(pending)
  amount              Decimal       @db.Decimal(14, 2)
  phone               String?
  checkoutRequestId   String        @unique
  merchantRequestId   String
  orderId             String
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([orderId])
}
