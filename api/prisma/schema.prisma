generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  buyer
  seller
  admin
  delivery
}

enum OrderStatus {
  pending
  paid
  completed
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum WalletTransactionType {
  /**
   * Buyer payment settled; funds held by platform, seller credited as pending (escrow).
   */
  order_escrow_in
  /**
   * Pickup verified; seller pending → available, platform releases liability.
   */
  order_escrow_release
  /**
   * Seller requested payout; available debited, payout record created.
   */
  payout_reserve
  /**
   * Payout marked paid externally (no further balance change).
   */
  payout_complete
  /**
   * Payout cancelled / failed; funds returned to seller available.
   */
  payout_cancel
  adjustment
}

enum PayoutStatus {
  pending
  paid
  failed
  cancelled
}

enum DisputeStatus {
  open
  reviewing
  resolved_refund
  resolved_no_action
  closed
}

enum NotificationType {
  order_update
  payment_success
  delivery_confirmation
}

/**
 * UI / API copy: English, አማርኛ (Amharic), Oromoo (Latin script).
 */
enum Locale {
  en
  am
  om
}

model User {
  id                  String          @id @default(cuid())
  name                String
  phone               String          @unique
  passwordHash        String
  role                Role            @default(buyer)
  failedLoginAttempts Int             @default(0)
  lockedUntil         DateTime?
  /**
   * When set, user cannot log in or call authenticated APIs.
   */
  bannedAt            DateTime?
  banReason           String?
  preferredLocale     Locale          @default(en)
  /**
   * Shop / pickup coordinates for sellers (optional). Used for nearby product search.
   */
  sellerLat           Float?
  sellerLng           Float?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  products            Product[]
  ordersAsBuyer       Order[]         @relation("BuyerOrders")
  ordersAsSeller      Order[]         @relation("SellerOrders")
  refreshTokens       RefreshToken[]
  wallet              Wallet?
  payouts             Payout[]
  notifications       Notification[]
  reviewsAsSeller     ProductReview[] @relation("SellerProductReviews")
  reviewsAsBuyer      ProductReview[] @relation("BuyerProductReviews")

  @@index([bannedAt])
}

/// Singleton financial config (fixed `id = 1`). Commission applied on escrow release to seller.
model PlatformSettings {
  id                Int      @id
  /**
   * Basis points: 100 = 1%, 500 = 5%. Taken from order total before crediting seller available balance.
   */
  commissionRateBps Int      @default(500)
  updatedAt         DateTime @updatedAt

  @@map("platform_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  note       String?  @db.Text
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Wallet {
  id               String              @id @default(cuid())
  /**
   * Set only for user wallets; null for the single platform treasury row.
   */
  userId           String?             @unique
  isPlatform       Boolean             @default(false)
  /**
   * Funds the platform has collected (escrow float).
   */
  availableBalance Decimal             @default(0) @db.Decimal(14, 2)
  /**
   * Seller: earnings awaiting pickup / dispute window (mirrors platform liability for that seller).
   */
  pendingBalance   Decimal             @default(0) @db.Decimal(14, 2)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     WalletTransaction[]
  payouts          Payout[]

  @@index([isPlatform])
  @@map("wallets")
}

model WalletTransaction {
  id        String                @id @default(cuid())
  walletId  String
  wallet    Wallet                @relation(fields: [walletId], references: [id], onDelete: Restrict)
  type      WalletTransactionType
  amount    Decimal               @db.Decimal(14, 2)
  orderId   String?
  paymentId String?
  payoutId  String?
  note      String?
  createdAt DateTime              @default(now())

  @@index([walletId])
  @@index([orderId])
  @@index([paymentId])
  @@index([payoutId])
  @@map("wallet_transactions")
}

model Payout {
  id          String       @id @default(cuid())
  walletId    String
  userId      String
  amount      Decimal      @db.Decimal(14, 2)
  status      PayoutStatus @default(pending)
  note        String?
  requestedAt DateTime     @default(now())
  completedAt DateTime?
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Restrict)
  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([walletId])
  @@index([status])
  @@map("payouts")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
}

model ProductGroup {
  id        String    @id @default(cuid())
  label     String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("product_groups")
}

model Product {
  id             String          @id @default(cuid())
  title          String
  description    String
  price          Decimal         @db.Decimal(14, 2)
  category       String
  lat            Float
  lng            Float
  /**
   * HTTPS URL from Cloudinary (or other CDN) after upload.
   */
  imageUrl       String?
  /**
   * Optional group for the same catalog item across sellers (price compare + related).
   */
  productGroupId String?         @map("product_group_id")
  productGroup   ProductGroup?   @relation(fields: [productGroupId], references: [id], onDelete: SetNull)
  sellerId       String
  seller         User            @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  orders         Order[]
  reviews        ProductReview[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([sellerId])
  @@index([category])
  @@index([category, price])
  @@index([productGroupId])
}

/**
 * One review per completed order (buyer). Drives product rating + seller trust signals.
 */
model ProductReview {
  id        String   @id @default(cuid())
  orderId   String   @unique @map("order_id")
  productId String   @map("product_id")
  sellerId  String   @map("seller_id")
  buyerId   String   @map("buyer_id")
  stars     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller    User     @relation("SellerProductReviews", fields: [sellerId], references: [id], onDelete: Restrict)
  buyer     User     @relation("BuyerProductReviews", fields: [buyerId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([sellerId])
  @@map("product_reviews")
}

model RequestLog {
  id         String   @id @default(cuid())
  method     String
  path       String
  statusCode Int
  durationMs Int
  userId     String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@map("request_logs")
}

model ErrorLog {
  id         String   @id @default(cuid())
  message    String
  stack      String?  @db.Text
  code       String?
  path       String?
  method     String?
  userId     String?
  statusCode Int?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@map("error_logs")
}

model Order {
  id                  String         @id @default(cuid())
  status              OrderStatus    @default(pending)
  quantity            Int
  totalPrice          Decimal        @db.Decimal(14, 2)
  buyerId             String
  sellerId            String
  productId           String
  /**
   * Secure one-time pickup token (raw); generated when payment succeeds — not the order id.
   */
  qrToken             String?        @unique
  qrConsumedAt        DateTime?
  /**
   * Seller marked delivery / handover complete → eligible for admin escrow release.
   */
  deliveryConfirmedAt DateTime?
  /**
   * Admin (or system) released escrow to seller available balance.
   */
  escrowReleasedAt    DateTime?
  /**
   * Free-form note when an admin overrides order fields.
   */
  adminOverrideNote   String?        @db.Text
  adminOverriddenAt   DateTime?
  buyer               User           @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  seller              User           @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  product             Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  payments            Payment[]
  disputes            Dispute[]
  notifications       Notification[]
  review              ProductReview?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([sellerId])
  @@index([productId])
  /**
   * Buyer order history: `WHERE buyerId = ? ORDER BY createdAt DESC` (replaces single-column buyerId index).
   */
  @@index([buyerId, createdAt(sort: Desc)])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  orderId   String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Dispute {
  id        String        @id @default(cuid())
  orderId   String        @map("order_id")
  reason    String
  status    DisputeStatus @default(open)
  /**
   * Optional admin resolution / internal note (set when updating status).
   */
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@map("disputes")
}

model Payment {
  id                String        @id @default(cuid())
  status            PaymentStatus @default(pending)
  amount            Decimal       @db.Decimal(14, 2)
  phone             String?
  checkoutRequestId String        @unique
  merchantRequestId String
  orderId           String
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([orderId])
}
